# agent雷达 — daily data cleanup cron job
# Runs every day at 08:30 Beijing time (Asia/Shanghai).
#
# Chain: 07:30 refresh → 08:00 email → 08:30 cleanup
#
# Prerequisites:
#   1. Server timezone set to Asia/Shanghai:
#      sudo timedatectl set-timezone Asia/Shanghai
#
# Install:
#   crontab -e
#   (paste the line below)

30 8 * * * cd /path/to/agent-radar && INFO_RADAR_CLEANUP_APPLY=true npm run radar:cleanup >> /var/log/agent-radar-cleanup.log 2>&1
